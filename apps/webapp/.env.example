VITE_API_URL=http://localhost:3001
VITE_DEV_INIT_DATA=
# Optional UI language override: uk | en
# VITE_UI_LOCALE=uk
# Optional Telegram WebApp top overlay fallback (pixels).
# VITE_TG_MOBILE_TOP_INSET_PX=56
# VITE_TG_IOS_TOP_INSET_PX=72
# Optional color thresholds for map point TTL (in minutes left).
# Defaults: TTL=300 (5h), green=200, orange=100.
VITE_POINT_TTL_MINUTES=300
VITE_POINT_GREEN_MINUTES_LEFT=200
VITE_POINT_ORANGE_MINUTES_LEFT=100
