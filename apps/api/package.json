    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@community-map/shared": "file:../../packages/shared",
    "@fastify/cors": "^9.0.1",
    "fastify": "^4.28.1",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.11",
    "tsx": "^4.19.1",
    "tsup": "^8.2.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
