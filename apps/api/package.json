{
  "name": "@community-map/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "start:prod": "tsx src/server.ts",
    "db:migrate": "tsx src/migrate.ts",
