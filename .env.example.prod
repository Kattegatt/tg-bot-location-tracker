# Copy this file to `.env.prod` on your VPS and fill in real secrets.
# Do not commit `.env.prod` to git.

APP_DOMAIN=app.communitymap.website
API_DOMAIN=api.communitymap.website
# Optional explicit frontend API URL override.
# If empty, build-webapp.sh uses https://${API_DOMAIN}
# VITE_API_URL=https://api.communitymap.website
# Optional UI language override for WebApp: uk | en
# If empty, language is detected from Telegram user language or browser language.
# VITE_UI_LOCALE=uk
# Optional Telegram WebApp top overlay fallback (pixels).
# Increase if Telegram "Close" button overlays the header on phones.
# VITE_TG_MOBILE_TOP_INSET_PX=56
# VITE_TG_IOS_TOP_INSET_PX=72
# Optional Telegram top bar height (pixels), added on top of reported safe-area.
# VITE_TG_TOP_BAR_HEIGHT_PX=52
# Optional point color thresholds for WebApp legend/coloring (minutes left).
# VITE_POINT_TTL_MINUTES=300
# VITE_POINT_GREEN_MINUTES_LEFT=240
# VITE_POINT_ORANGE_MINUTES_LEFT=120

POSTGRES_PASSWORD=replace_with_strong_password
BOT_TOKEN=replace_with_telegram_bot_token
BOT_API_TOKEN=replace_with_internal_bot_api_token
# Optional values shown in bot /help donation section:
# DONATE_MONO_CARD=4441111122223333
# DONATE_CRYPTO_WALLET=0xYourWalletAddress
ADMIN_TOKEN=replace_with_admin_token
INITDATA_MAX_AGE_SECONDS=86400
